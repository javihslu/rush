{
    "name": "Rush",
    "dockerComposeFile": "../docker-compose.yaml",
    "service": "dev",
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/app/.venv/bin/python",
                "python.terminal.activateEnvironment": false
            },
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "redhat.vscode-yaml"
            ]
        }
    },
    "forwardPorts": [],
    "portsAttributes": {},
    "otherPortsAttributes": {
        "onAutoForward": "notify"
    },
    "postCreateCommand": "uv sync",
    "remoteUser": "root"
}