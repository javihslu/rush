{
    "name": "Rush",
    "dockerComposeFile": "../docker-compose.yaml",
    "service": "dev",
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/app/.venv/bin/python",
                "python.terminal.activateEnvironment": false,
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff"
                }
            },
            "extensions": [
                "ms-python.python",
                "charliermarsh.ruff",
                "ms-toolsai.jupyter",
                "redhat.vscode-yaml"
            ]
        }
    },
    "forwardPorts": [
        5432,
        8085
    ],
    "portsAttributes": {
        "5432": {
            "label": "PostgreSQL"
        },
        "8085": {
            "label": "pgAdmin"
        }
    },
    "postCreateCommand": "uv sync",
    "remoteUser": "root"
}