# Reference only — setup.sh generates .env from config.yaml.
# Edit config.yaml instead of this file.

# PostgreSQL
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=rush
POSTGRES_HOST=pgdatabase
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=root

# Airflow
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow
