# Force LF line endings for all text files (prevents CRLF issues on Windows)
* text=auto eol=lf

# Explicitly mark shell scripts
*.sh text eol=lf

# Explicitly mark config files
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.py text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.json text eol=lf

# Mark binary files
*.pdf binary
*.parquet binary
*.db binary
*.duckdb binary
